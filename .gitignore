# Claude Code local state and kit scaffolding, edited out-of-band not via git
.claude/
.devcontainer/
CLAUDE.local.md

# Local backup snapshot of the kit directories above
agent-workshop-kit-backup.tar.gz

# Editor and OS noise
.DS_Store
.vscode/
.idea/
*.swp
*~

# Windows Mark-of-the-Web sidecars, materialised when files downloaded on
# Windows are copied into a Linux filesystem that has no alternate data streams
*:Zone.Identifier

# Common temp dirs that show up regardless of language
tmp/
.cache/

# Node, here because the dev container has Node and you may add it later
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Go
*.exe
*.test
*.out

# Rust
target/

# Environment files (covered by the protect-paths hook too, but belt and braces)
.env
.env.local
.env.*.local
